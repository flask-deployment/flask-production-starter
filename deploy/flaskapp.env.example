# systemd EnvironmentFile for the Gunicorn service.
# Install to /etc/flaskapp/flaskapp.env, then lock it down:
#   sudo chown root:root /etc/flaskapp/flaskapp.env && sudo chmod 600 /etc/flaskapp/flaskapp.env
# Guide: https://flask-deployment.com/deploy/flask-environment-variables-and-secrets-setup

FLASK_CONFIG=production
FLASK_DEBUG=0
SECRET_KEY=change-me
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/appdb
